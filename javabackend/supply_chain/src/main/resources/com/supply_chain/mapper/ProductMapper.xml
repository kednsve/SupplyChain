    <sql id="selectSql">
        select p.id,
               p.name,
               p.image,
               p.price,
               p.category_id,
               c.name categoryName,
               p.department_id,
               d.name departmentName
        from product p
                 left join department d on p.department_id = d.id
                 left join category c on p.category_id = c.id
    </sql>
    <select id="getProducts" resultType="com.supply_chain.vo.ProductVO">
        <include refid="selectSql"/>
        ${ew.customSqlSegment}
    </select>
    <select id="selById" resultType="com.supply_chain.vo.ProductVO">
        <include refid="selectSql"/>
        ${ew.customSqlSegment}
    </select>
